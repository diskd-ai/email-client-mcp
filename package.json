{
  "name": "@diskd-ai/email-client-mcp",
  "version": "0.1.14",
  "description": "Drive-backed multi-account email MCP with reliable IMAP-to-mailboxes sync.",
  "license": "LGPL-3.0-or-later",
  "repository": {
    "type": "git",
    "url": "https://github.com/diskd-ai/email-client-mcp"
  },
  "type": "module",
  "bin": {
    "email-client-mcp": "dist/server.js"
  },
  "main": "./dist/server.js",
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=24.0.0"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "test": "vitest run",
    "test:watch": "vitest",
    "start": "node dist/server.js stdio",
    "dev": "tsx src/server.ts stdio",
    "prepublishOnly": "bun run build && bun run test"
  },
  "dependencies": {
    "@diskd-ai/sdk": "5.1.3",
    "@modelcontextprotocol/sdk": "^1.26.0",
    "imapflow": "^1.2.9",
    "smol-toml": "^1.6.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.7",
    "@types/node": "^22.10.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vitest": "^2.1.5"
  }
}
